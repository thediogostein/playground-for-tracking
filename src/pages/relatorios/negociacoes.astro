---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="NegociaГ§Гµes вЂ” RelatГіrios" description="Lista de negociaГ§Гµes com histГіrico de movimentaГ§Гµes">
  <div class="space-y-6">
    <div class="flex items-center gap-4">
      <a href="/relatorios" class="text-sm text-muted-foreground hover:text-primary transition-colors">&larr; RelatГіrios</a>
      <h1 class="text-3xl font-bold tracking-tight">рџ“‹ NegociaГ§Гµes</h1>
    </div>

    <div class="flex items-center justify-between mb-2">
      <span id="refresh-status" class="text-xs text-muted-foreground">вЏі Carregando...</span>
      <button id="refresh-btn" onclick="loadDeals()" class="text-xs px-3 py-1 rounded border border-border hover:bg-muted transition-colors">рџ”„ Atualizar</button>
    </div>

    <div id="report-deals" class="space-y-2"></div>
  </div>
</BaseLayout>

<script>
  const statusColors: Record<string, string> = {
    'Em andamento': 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
    'Ganho': 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300',
    'Perdido': 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300',
  };

  const stageEmojis: Record<string, string> = {
    'Novo_Lead': 'рџ†•',
    'Em_Cadencia': 'рџ“ћ',
    'Ja_Conectou': 'вњ…',
    'Em_Agenda': 'рџ“…',
    'Fez_Reuniao': 'рџ¤ќ',
  };

  const eventLabels: Record<string, string> = {
    'deal_created': 'NegociaГ§ГЈo criada',
    'stage_changed': 'Mudou de etapa',
    'status_changed': 'Mudou de status',
  };

  async function loadMovements(dealId: number, rowEl: HTMLElement) {
    const existing = rowEl.nextElementSibling;
    if (existing && existing.classList.contains('movement-row')) {
      existing.remove();
      return;
    }

    try {
      const res = await fetch('/api/reports?type=movements&dealId=' + dealId);
      const data = await res.json();
      const movements = data.movements || [];

      const tr = document.createElement('tr');
      tr.className = 'movement-row bg-muted/20';
      tr.innerHTML = '<td colspan="8" class="p-3"><div class="text-xs font-semibold mb-2 text-muted-foreground">рџ“њ HistГіrico de MovimentaГ§Гµes</div><div id="mov-' + dealId + '" class="space-y-1"></div></td>';
      rowEl.after(tr);

      const container = document.getElementById('mov-' + dealId)!;
      if (movements.length === 0) {
        container.innerHTML = '<span class="text-xs text-muted-foreground">Nenhuma movimentaГ§ГЈo registrada.</span>';
        return;
      }

      for (const m of movements) {
        let desc = '';
        if (m.event === 'deal_created') {
          desc = 'рџџў <b>NegociaГ§ГЈo criada</b>';
        } else if (m.event === 'stage_changed') {
          desc = 'рџ”Ђ De <b>' + (m.oldStage || '?').replace(/_/g,' ') + '</b> в†’ <b>' + (m.newStage || '?').replace(/_/g,' ') + '</b>';
        } else if (m.event === 'status_changed') {
          desc = 'рџЏЃ Status: <b>' + (m.oldStatus || '?') + '</b> в†’ <b>' + (m.newStatus || '?') + '</b>';
        }
        const date = m.createdAt ? new Date(m.createdAt).toLocaleString('pt-BR') : '?';
        container.innerHTML += '<div class="flex items-center gap-3 text-xs py-1 border-b border-border/30"><span class="text-muted-foreground w-36">' + date + '</span><span>' + desc + '</span></div>';
      }
    } catch {
      // ignore
    }
  }

  async function loadDeals() {
    try {
      const res = await fetch('/api/reports?type=funnel');
      const data = await res.json();

      if (data.error) { document.getElementById('report-deals')!.innerHTML = '<p class="text-red-500">Erro: '+data.error+'</p>'; return; }

      const container = document.getElementById('report-deals')!;
      let html = '<div class="rounded-xl border bg-card overflow-x-auto"><table class="w-full text-sm"><thead><tr class="border-b bg-muted/30">';
      html += '<th class="text-left p-3">NegociaГ§ГЈo</th>';
      html += '<th class="text-left p-3">Empresa</th>';
      html += '<th class="text-center p-3">EstГЎgio</th>';
      html += '<th class="text-center p-3">Status</th>';
      html += '<th class="text-center p-3">Valor</th>';
      html += '<th class="text-left p-3">UTM Source</th>';
      html += '<th class="text-left p-3">Campaign</th>';
      html += '<th class="text-center p-3">Criado</th>';
      html += '</tr></thead><tbody id="deals-tbody">';

      for (const d of data.details) {
        const emoji = stageEmojis[d.stage] || 'вЂў';
        const badge = statusColors[d.status] || 'bg-gray-100';
        const created = d.createdAt ? new Date(d.createdAt).toLocaleDateString('pt-BR') : 'вЂ”';
        html += '<tr class="border-b hover:bg-muted/20 cursor-pointer deal-row" data-deal-id="' + d.id + '">';
        html += '<td class="p-3 font-medium">' + d.title + '</td>';
        html += '<td class="p-3 text-muted-foreground">' + (d.org || 'вЂ”') + '</td>';
        html += '<td class="p-3 text-center text-xs">' + emoji + ' ' + d.stage.replace(/_/g,' ') + '</td>';
        html += '<td class="p-3 text-center"><span class="px-2 py-0.5 rounded text-xs font-medium ' + badge + '">' + d.status + '</span></td>';
        html += '<td class="p-3 text-center font-mono text-xs">' + (d.value > 0 ? 'R$ ' + d.value : 'вЂ”') + '</td>';
        html += '<td class="p-3 text-xs text-muted-foreground">' + (d.utm_source || 'вЂ”') + '</td>';
        html += '<td class="p-3 text-xs text-muted-foreground max-w-[120px] truncate" title="' + (d.utm_campaign || '') + '">' + (d.utm_campaign || 'вЂ”') + '</td>';
        html += '<td class="p-3 text-center text-xs text-muted-foreground">' + created + '</td>';
        html += '</tr>';
      }

      html += '</tbody></table></div>';
      html += '<p class="text-xs text-muted-foreground mt-2">рџ’Ў Clique em uma linha para ver o histГіrico de movimentaГ§Гµes.</p>';
      container.innerHTML = html;

      // Event delegation вЂ” click on any deal row
      container.querySelector('table')?.addEventListener('click', (e) => {
        const row = (e.target as HTMLElement).closest('.deal-row') as HTMLElement;
        if (!row) return;
        const dealId = parseInt(row.dataset.dealId || '0');
        loadMovements(dealId, row);
      });
    } catch (err) {
      document.getElementById('report-deals')!.innerHTML = '<p class="text-red-500">Erro ao carregar dados.</p>';
    }
    document.getElementById('refresh-status')!.textContent = 'рџџў Atualizado ' + new Date().toLocaleTimeString('pt-BR');
  }
  loadDeals();
  setInterval(loadDeals, 30000);
</script>
